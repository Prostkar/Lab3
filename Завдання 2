#include <stdio.h>
#include <locale.h>

int main() {
    setlocale(LC_ALL, "uk_UA.UTF-8");

    double a, b, c;

    printf("Користувач будь ласка введiть a, b, c: ");
    scanf_s("%lf %lf %lf", &a, &b, &c);

    if (a < b && b < c) {

        a = 2 * a;
        b = 2 * b;
        c = 2 * c;

        printf("Числа зростають. Подвоєнi значення:\n");
        printf("a = %.2lf, b = %.2lf, c = %.2lf\n", a, b, c);
    }
    else {

        if (a == 0 || b == 0 || c == 0) {
            printf("Неможливо обчислити: дiлення на нуль\n");
        }
        else {
            a = 1 / a;
            b = 1 / b;
            c = 1 / c;

            printf("Числа не зростають. Оберненi значення:\n");
            printf("a = %.2lf, b = %.2lf, c = %.2lf\n", a, b, c);
        }
    }

    return 0;
}
